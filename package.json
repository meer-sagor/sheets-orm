{
  "name": "@meersagor/sheets-orm",
  "version": "1.0.0",
  "description": "TypeScript ORM for Google Sheets with support for OAuth (multi-tenant) and Service Account modes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/examples/usage.ts",
    "start": "node dist/examples/usage.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "yalc:publish": "npm run build && yalc publish",
    "yalc:push": "npm run build && yalc push"
  },
  "keywords": [
    "google-sheets",
    "orm",
    "orm",
    "google-sheets",
    "typescript",
    "database",
    "database",
    "typescript",
    "cache",
    "oauth",
    "multi-tenant",
    "googleapis",
    "saas",
    "spreadsheet",
    "decorators",
    "query-builder"
  ],
  "author": "Meer Sagor",
  "license": "MIT",
  "dependencies": {
    "googleapis": "^167.0.0",
    "node-cache": "^5.1.2",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/node-cache": "^4.2.5",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "yalc": "latest"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
