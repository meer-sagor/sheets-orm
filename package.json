{
  "name": "sheets-orm",
  "version": "1.0.0",
  "description": "TypeORM-like ORM for Google Sheets with caching and advanced query support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/examples/usage.ts",
    "start": "node dist/examples/usage.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "orm",
    "google-sheets",
    "database",
    "typescript",
    "cache",
    "googleapis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "googleapis": "^167.0.0",
    "node-cache": "^5.1.2",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/node-cache": "^4.2.5",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
