{
  "name": "google-sheets-orm",
  "version": "1.0.0",
  "description": "TypeORM-like ORM for Google Sheets with caching and advanced query support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/examples/usage.ts",
    "start": "node dist/examples/usage.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "orm",
    "google-sheets",
    "database",
    "typescript",
    "cache",
    "googleapis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "googleapis": "^128.0.0",
    "node-cache": "^5.1.2",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/node-cache": "^4.2.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
